{
  "manifest_version": 3,
  "name": "History Revamped",
  "version": "1.0.1",
  "description": "A beautiful, analytics-driven replacement for your Chrome history.",
  "permissions": [
    "history",
    "storage",
    "favicon",
    "tabs"
  ],
  "chrome_url_overrides": {
    "history": "src/history.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "icons": {
    "16": "public/icon-16.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  }
}